# AegisOps AI Configuration

# Gemini API Key (Required for live Gemini calls. If left empty, Simulation Fallback mode will run)
GEMINI_API_KEY=

# Database Configuration (Defaults to SQLite in-memory/local file if omitted)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/aegisops

# Server Port (Default is 8000)
PORT=8000
